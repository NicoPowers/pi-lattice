{
  "name": "pi-agent-orchestrator-dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/pi-agent-orchestrator",
  "remoteUser": "node",
  "mounts": [
    "source=pi-agent-orchestrator-home,target=/home/node/.pi,type=volume",
    "source=pi-agent-orchestrator-bun-cache,target=/home/node/.bun/install/cache,type=volume",
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "forwardPorts": [18765],
  "postCreateCommand": "bash .devcontainer/dev-setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "oven.bun-vscode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
