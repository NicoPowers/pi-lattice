{
  "name": "pi-lattice-dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/pi-lattice",
  "remoteUser": "node",
  "initializeCommand": "bash .devcontainer/init-ssh-agent.sh",
  "mounts": [
    "source=pi-lattice-home,target=/home/node/.pi,type=volume",
    "source=pi-lattice-bun-cache,target=/home/node/.bun/install/cache,type=volume",
    "source=/tmp/pi-lattice-ssh-agent,target=/tmp/pi-lattice-ssh-agent,type=bind"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/tmp/pi-lattice-ssh-agent/agent.sock"
  },
  "forwardPorts": [18765],
  "postCreateCommand": "bash .devcontainer/dev-setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "oven.bun-vscode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
